# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Python files always LF
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.csv text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
